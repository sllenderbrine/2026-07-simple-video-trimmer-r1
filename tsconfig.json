{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "strict": true,

    "noUncheckedIndexedAccess": true,

    "inlineSourceMap": true,
    "inlineSources": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["node_modules"],
}