{
  "name": "2026-07-video-trim-fast-r1",
  "version": "1.1",
  "description": "A simple video editor for quickly editing and renaming a large amount of clips",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "tsc",
    "auto-build": "tsc --watch",
    "start": "npm run build && electron .",
    "package": "npm run build && electron-builder",
    "package-dev": "npm run build && electron-builder --dir"
  },
  "build": {
    "appId": "com.sllenderbrine.simplevideotrimmer",
    "productName": "SimpleVideoTrimmer",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "resources/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "electron-builder": "^26.15.3",
    "typescript": "^6.0.3",
    "electron": "^43.0.0"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0"
  }
}
